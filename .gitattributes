# Normalise line endings: store LF in the repo, check out native on Windows.
# Silences the "LF will be replaced by CRLF" warnings and keeps diffs clean.
* text=auto eol=lf

# Explicitly treat known text types as text.
*.ts   text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.env  text eol=lf

# Treat binary assets as binary (never normalise).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webm binary
*.zip  binary
*.ico  binary
