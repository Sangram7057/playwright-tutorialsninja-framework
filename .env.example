# ----------------------------------------------------------------------------
# Sample environment file. Copy to `.env` (or `.env.qa`) and fill real values.
# NEVER commit a populated `.env` — only this example is tracked in git.
# ----------------------------------------------------------------------------

# Active environment: qa | staging | prod
TEST_ENV=qa

# Application under test
BASE_URL=https://tutorialsninja.com/demo/

# Execution
BROWSER=chromium
HEADLESS=true
WORKERS=
RETRIES=0

# Full guest order-placement E2E (off by default; needs guest checkout enabled).
# See docs/local-opencart.md.
RUN_CHECKOUT_E2E=false

# Timeouts (milliseconds) — generous action timeout suits the latency-prone demo
ACTION_TIMEOUT=30000
NAVIGATION_TIMEOUT=30000
EXPECT_TIMEOUT=10000

# Logging: error | warn | info | http | verbose | debug
LOG_LEVEL=info

# Seeded test account (use a throwaway demo account, not real credentials)
STANDARD_USER_EMAIL=
STANDARD_USER_PASSWORD=
